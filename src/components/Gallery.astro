---
import { content } from '../data/content';
const { gallery } = content;
---
<section class="py-16 px-4 sm:px-6 max-w-6xl mx-auto">
    <div class="text-center space-y-3 mb-12">
        <span class="text-xs font-semibold tracking-wider text-sage uppercase block" data-lang="en">{gallery.subtitle.en}</span>
        <span class="text-xs font-semibold tracking-wider text-sage uppercase block" data-lang="hi">{gallery.subtitle.hi}</span>
        
        <h2 class="text-2xl sm:text-3xl font-serif font-bold text-forest">
            <span data-lang="en">{gallery.title.en}</span>
            <span data-lang="hi">{gallery.title.hi}</span>
        </h2>
        
        <p class="text-sm sm:text-base text-forest/70 max-w-xl mx-auto">
            <span data-lang="en">{gallery.description.en}</span>
            <span data-lang="hi">{gallery.description.hi}</span>
        </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {gallery.items.map((item) => (
            item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" 
                   class="group relative rounded-2xl overflow-hidden shadow-md bg-white border border-forest/5 aspect-[4/3] flex items-center justify-center focus:outline-none focus:ring-2 focus:ring-sage"
                   aria-label={item.alt}>
                    <img src={item.image} alt={item.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-500 opacity-90" />
                    <div class="absolute inset-0 bg-forest/30 flex items-center justify-center group-hover:bg-forest/40 transition-colors">
                        <div class="w-14 h-14 bg-warmcream text-forest rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 active:scale-95 transition-transform duration-200">
                            <svg class="w-6 h-6 ml-1 text-forest fill-current" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z" />
                            </svg>
                        </div>
                    </div>
                    <div class="absolute bottom-4 left-4 right-4 flex flex-col text-left">
                        <span class="text-white font-serif text-base sm:text-lg font-bold" data-lang="en">{item.title.en}</span>
                        <span class="text-white font-serif text-base sm:text-lg font-bold" data-lang="hi">{item.title.hi}</span>
                        <span class="text-[11px] text-warmcream/80 font-semibold tracking-wider uppercase" data-lang="en">{item.category.en}</span>
                        <span class="text-[11px] text-warmcream/80 font-semibold tracking-wider uppercase" data-lang="hi">{item.category.hi}</span>
                    </div>
                </a>
            ) : (
                <div class="group relative rounded-2xl overflow-hidden shadow-md bg-white border border-forest/5 aspect-[4/3] flex items-center justify-center">
                    <img src={item.image} alt={item.alt} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-500" />
                    <div class="absolute inset-0 bg-gradient-to-t from-forest/80 via-forest/20 to-transparent flex flex-col justify-end p-4 text-left">
                        <span class="text-warmcream font-serif text-base sm:text-lg font-bold" data-lang="en">{item.title.en}</span>
                        <span class="text-warmcream font-serif text-base sm:text-lg font-bold" data-lang="hi">{item.title.hi}</span>
                        <span class="text-[11px] text-sage-light font-semibold tracking-wider uppercase mt-0.5" data-lang="en">{item.category.en}</span>
                        <span class="text-[11px] text-sage-light font-semibold tracking-wider uppercase mt-0.5" data-lang="hi">{item.category.hi}</span>
                    </div>
                </div>
            )
        ))}
    </div>
</section>
