---
import { content } from '../data/content';
const { stats } = content;
---
<section class="py-16 px-4 sm:px-6 max-w-6xl mx-auto border-t border-forest/5">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <div class="md:col-span-5 space-y-4">
            <h2 class="text-2xl sm:text-3xl font-serif font-bold text-forest leading-snug">
                <span data-lang="en">Bridging Ancient Wisdom with Modern Lives</span>
                <span data-lang="hi">प्राचीन ज्ञान और आधुनिक जीवन का संगम</span>
            </h2>
            <div class="w-16 h-1 bg-sage rounded-full"></div>
        </div>

        <div class="md:col-span-7">
            <div class="relative pl-8 border-l-2 border-forest/5 space-y-10">
                {stats.map((stat) => (
                    <div class="relative">
                        <span class="absolute -left-[31px] top-1.5 bg-sage text-warmcream p-1 rounded-full w-4 h-4 flex items-center justify-center">
                            <span class="w-1.5 h-1.5 bg-warmcream rounded-full"></span>
                        </span>
                        <h4 class="font-serif text-base sm:text-lg font-bold text-forest">
                            <span data-lang="en">{stat.title.en}</span>
                            <span data-lang="hi">{stat.title.hi}</span>
                        </h4>
                        <p class="text-xs sm:text-sm text-forest/75 mt-1">
                            <span data-lang="en">{stat.description.en}</span>
                            <span data-lang="hi">{stat.description.hi}</span>
                        </p>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>
